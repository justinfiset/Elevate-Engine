# ImGui project Ninja build file generated by Premake
ninja_required_version = 1.6

rule cc_emcc
  command = emcc $cflags -c $in -o $out
  deps = gcc
  depfile = $out.d
  description = Compiling C source $in

rule cxx_emcc
  command = em++ $cxxflags -c $in -o $out
  deps = gcc
  depfile = $out.d
  description = Compiling C++ source $in

rule rc_emcc
  command = nil -i $in -o $out $resflags
  description = Compiling resource $in

rule ar_emcc
  command = emar.bat -rcs $out @$out.rsp
  rspfile = $out.rsp
  rspfile_content = $in
  description = Archiving static library $out

rule pch_emcc
  command = emcc -x c-header $cflags -o $out -MD -MF $out.d -c $in
  description = Generating precompiled header $in
  depfile = $out.d

rule copy
  command = cp -f $in $out
  description = Copying file $in to $out

rule prebuild
  command = $prebuildcommands
  description = Running pre-build commands

rule prelink
  command = $prelinkcommands
  description = Running pre-link commands

rule postbuild
  command = $postbuildcommands
  description = Running post-build commands

rule custom
  command = $customcommand
  description = Running custom command: $customcommand

rule cc_gcc
  command = gcc $cflags -c $in -o $out
  deps = gcc
  depfile = $out.d
  description = Compiling C source $in

rule cxx_gcc
  command = g++ $cxxflags -c $in -o $out
  deps = gcc
  depfile = $out.d
  description = Compiling C++ source $in

rule rc_gcc
  command = windres -i $in -o $out $resflags
  description = Compiling resource $in

rule ar_gcc
  command = emar.bat -rcs $out @$out.rsp
  rspfile = $out.rsp
  rspfile_content = $in
  description = Archiving static library $out

rule pch_gcc
  command = gcc -x c-header $cflags -o $out -MD -MF $out.d -c $in
  description = Generating precompiled header $in
  depfile = $out.d






rule cc_clang
  command = cmd /c emcc.bat $cflags -c $in -o $out
  deps = gcc
  depfile = $out.d
  description = Compiling C source $in

rule cxx_clang
  command = cmd /c em++.bat $cxxflags -c $in -o $out
  deps = gcc
  depfile = $out.d
  description = Compiling C++ source $in

rule rc_clang
  command = windres -i $in -o $out $resflags
  description = Compiling resource $in

rule ar_clang
  command = emar.bat -rcs $out @$out.rsp
  rspfile = $out.rsp
  rspfile_content = $in
  description = Archiving static library $out

rule pch_clang
  command = cmd /c emcc.bat -x c-header $cflags -o $out -MD -MF $out.d -c $in
  description = Generating precompiled header $in
  depfile = $out.d






